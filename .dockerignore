# Mantener la imagen liviana y reproducible
.git/
.gitignore
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# No incluir el frontend ni documentación en la imagen de la API
frontend/
docs/
*.docx
*.md
DEPLOY_RUNBOOK.md

# Datos locales y secretos
*.db
*.sqlite3
.env
.env.*
!.env.example
storage/raw/*
!storage/raw/.gitkeep
