# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/genz_api
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/genz_api

# Supabase (si usas Supabase cloud, reemplaza los valores)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Application
APP_NAME=GenZ Colombia API
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Rate Limiting
RATE_LIMIT_FREE=100/minute
RATE_LIMIT_PRO=1000/minute
RATE_LIMIT_ENTERPRISE=10000/minute

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
